{
  "name": "@copilot_bom/bowl",
  "version": "0.0.0",
  "private": true,
  "main": "dist/server.js",
  "license": "MIT",
  "scripts": {
    "dev:payload": "bom env PAYLOAD_CONFIG_PATH=src/payload.config.ts nodemon",
    "dev": "run-s dev:*",
    "build:copy": "copyfiles -u 1 \"src/**/*.{html,css,scss,ttf,woff,woff2,eot,svg,jpg,png}\" dist/",
    "build:payload": "bom env PAYLOAD_CONFIG_PATH=src/payload.config.ts NODE_ENV=production payload build",
    "build:server": "tsc",
    "build": "run-s build:*",
    "serve": "bom env PAYLOAD_CONFIG_PATH=dist/payload.config.js NODE_ENV=production ts-node dist/server.js",
    "start:serve": "npm run serve",
    "start": "run-s start:*",
    "generate:types": "bom env PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:types",
    "generate:graphQLSchema": "PAYLOAD_CONFIG_PATH=src/payload.config.ts payload generate:graphQLSchema",
    "test:integration": "jest",
    "test": "run-s test:*",
    "test-watch": "npm test -- --watch --silent=false",
    "test-e2e:install": "playwright install",
    "test-e2e:test": "playwright test",
    "test-e2e": "run-s test-e2e:*",
    "coverage:integration": "npm run test:integration -- --coverage",
    "coverage": "run-s -c --silent coverage:*",
    "migrate:create": "bom env MONGODB_URI=\"{MONGODB_URI}\" PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate:create --file @payloadcms/db-mongodb/versions-v1-v2",
    "migrate:run": "bom env MONGODB_URI=\"{MONGODB_URI}\" PAYLOAD_CONFIG_PATH=src/payload.config.ts payload migrate"
  },
  "dependencies": {
    "@azure/storage-blob": "^12.17.0",
    "@payloadcms/bundler-webpack": "^1.0.5",
    "@payloadcms/db-mongodb": "^1.2.0",
    "@payloadcms/plugin-cloud-storage": "1.1.1",
    "@payloadcms/plugin-cloud": "^2.2.6",
    "@payloadcms/plugin-seo": "^1.0.15",
    "@payloadcms/richtext-slate": "^1.3.1",
    "@websolutespa/bom-core": "latest",
    "@websolutespa/bom-env": "latest",
    "@websolutespa/payload-plugin-bowl": "latest",
    "@websolutespa/payload-plugin-cloud-storage-fs": "latest",
    "@websolutespa/payload-plugin-cron-job": "latest",
    "@websolutespa/payload-plugin-localization": "latest",
    "@websolutespa/payload-plugin-search": "latest",
    "@websolutespa/payload-plugin-seed": "latest",
    "@websolutespa/payload-plugin-seo": "latest",
    "@websolutespa/payload-plugin-thron": "latest",
    "@websolutespa/payload-utils": "latest",
    "express": "^4.17.1",
    "node-cron": "^3.0.3",
    "payload": "2.28.0"
  },
  "devDependencies": {
    "@swc/core": "1.3.107",
    "@swc/jest": "^0.2.36",
    "@swc/register": "0.1.10",
    "@types/express": "^4.17.9",
    "@websolutespa/test": "latest",
    "@websolutespa/tsconfig": "latest",
    "copyfiles": "^2.4.1",
    "eslint-config-websolute": "*",
    "eslint": "^8.56.0",
    "nodemon": "^3.1.0",
    "npm-run-all": "^4.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  },
  "overrides": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  },
  "resolutions": {
    "jackspeak": "2.1.1"
  }
}