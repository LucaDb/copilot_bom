{
  "name": "@copilot_bom/web",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "pre:clean": "rimraf public/* \"!public/.gitkeep\"",
    "pre:copy": "copyfiles \"../public/**/*\" \"./public\"",
    "pre:mock": "bom mock ./store",
    "next:mock": "wait-on .mixer/store.json",
    "next:next:watch": "bom mock ./store watch",
    "next:next:dev": "next dev",
    "next:next": "run-p next:next:*",
    "dev:pre": "run-p pre:*",
    "dev:next": "run-s next:*",
    "dev": "run-p dev:*",
    "build:clean": "rimraf public/* \"!public/.gitkeep\"",
    "build:copy": "copyfiles -V \"../public/**/*\" \"./public\"",
    "build:mock": "bom mock ./store",
    "build:wait": "wait-on .mixer/store.json",
    "build:next": "next build",
    "build": "run-s build:*",
    "info": "next info",
    "start": "next start -p 3000",
    "lint": "next lint",
    "test:integration": "jest",
    "test": "run-s test:*",
    "test-watch": "npm test -- --watch --silent=false",
    "test-e2e:install": "playwright install",
    "test-e2e:test": "playwright test",
    "test-e2e": "run-s test-e2e:*",
    "coverage:integration": "npm run test:integration -- --coverage",
    "coverage": "run-s -c --silent coverage:*"
  },
  "dependencies": {
    "@ariakit/react": "^0.4.11",
    "@copilot_bom/icons": "*",
    "@copilot_bom/models": "*",
    "@copilot_bom/ui": "*",
    "@websolutespa/bom-core": "latest",
    "@websolutespa/bom-mixer-forms": "latest",
    "@websolutespa/bom-mixer-hooks": "latest",
    "@websolutespa/bom-mixer-icons": "latest",
    "@websolutespa/bom-mixer-image": "latest",
    "@websolutespa/bom-mixer-models": "latest",
    "@websolutespa/bom-mixer-store": "latest",
    "@websolutespa/bom-mixer-ui": "latest",
    "@websolutespa/payload-bowl-live-preview": "latest",
    "framer-motion": "^7.2.1",
    "html-to-text": "^9.0.5",
    "iron-session": "^8.0.3",
    "lenis": "^1.0.45",
    "next": "^14.1.4",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.11",
    "react-lottie-player": "^2.0.0",
    "react": "^18.2.0",
    "sharp": "0.30.4",
    "styled-components": "^5.3.11",
    "swiper": "^8.3.2",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@axe-core/react": "^4.7.3",
    "@babel/core": "^7.0.0",
    "@next/bundle-analyzer": "^12.3.1",
    "@svgr/webpack": "^6.3.1",
    "@types/html-to-text": "^9.0.4",
    "@types/node": "^20.12.7",
    "@types/react-dom": "^18.2.24",
    "@types/react": "^18.2.75",
    "@types/styled-components": "^5.1.26",
    "@websolutespa/bom-env": "latest",
    "@websolutespa/test": "latest",
    "@websolutespa/tsconfig": "latest",
    "copyfiles": "^2.4.1",
    "eslint-config-websolute": "*",
    "eslint": "^8.56.0",
    "npm-run-all": "^4.1.5",
    "raw-loader": "^4.0.2",
    "rimraf": "3.0.2",
    "schema-dts": "^1.1.5",
    "typescript": "^5.4.5",
    "wait-on": "^7.0.1"
  }
}