{
  "name": "@copilot_bom/storybook",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev:clean": "rimraf \"public/**/!(.gitkeep)\"",
    "dev:copy": "copyfiles \"../public/**/*\" \"./public\"",
    "dev:storybook": "storybook dev --quiet --ci -c .storybook -p 3002",
    "dev": "run-s dev:*",
    "build:clean": "rimraf \"public/**/!(.gitkeep)\"",
    "build:copy": "copyfiles -V \"../public/**/*\" \"./public\"",
    "build:storybook": "storybook build --quiet -c .storybook -o .storybook-dist",
    "build": "run-s build:*",
    "start": "serve .storybook-dist"
  },
  "dependencies": {
    "@ariakit/react": "^0.4.11",
    "@copilot_bom/icons": "*",
    "@copilot_bom/models": "*",
    "@copilot_bom/ui": "*",
    "@websolutespa/bom-core": "latest",
    "@websolutespa/bom-mixer-forms": "latest",
    "@websolutespa/bom-mixer-hooks": "latest",
    "@websolutespa/bom-mixer-icons": "latest",
    "@websolutespa/bom-mixer-models": "latest",
    "@websolutespa/bom-mixer-store": "latest",
    "@websolutespa/bom-mixer-ui": "latest",
    "framer-motion": "^7.2.1",
    "iron-session": "^8.0.3",
    "next": "^14.1.4",
    "react-dom": "^18.2.0",
    "react": "^18.2.0",
    "styled-components": "^5.3.11",
    "swiper": "^8.3.2",
    "zustand": "^4.4.0"
  },
  "devDependencies": {
    "@storybook/addon-essentials": "^7.4.0",
    "@storybook/addon-interactions": "^7.4.0",
    "@storybook/addon-links": "^7.4.0",
    "@storybook/addon-styling": "^1.3.7",
    "@storybook/blocks": "^7.4.0",
    "@storybook/nextjs": "^7.4.0",
    "@storybook/react": "^7.4.0",
    "@storybook/testing-library": "^0.2.0",
    "@svgr/webpack": "^6.3.1",
    "@types/node": "^20.12.7",
    "@types/react-dom": "^18.2.24",
    "@types/react": "^18.2.75",
    "@types/styled-components": "^5.1.26",
    "@websolutespa/bom-env": "latest",
    "@websolutespa/test": "latest",
    "@websolutespa/tsconfig": "latest",
    "copyfiles": "^2.4.1",
    "eslint-config-websolute": "*",
    "eslint": "^8.56.0",
    "npm-run-all": "^4.1.5",
    "raw-loader": "^4.0.2",
    "rimraf": "3.0.2",
    "serve": "^14.0.1",
    "storybook-addon-next": "^1.8.0",
    "storybook-addon-styled-component-theme": "^2.0.0",
    "storybook": "^7.4.0",
    "tsconfig-paths-webpack-plugin": "^3.5.2",
    "typescript": "^5.4.5"
  }
}