{
  "name": "@copilot_bom/ui",
  "version": "0.0.0",
  "private": true,
  "description": "Mixer UI module of the BOM Repository",
  "keywords": [
    "bom",
    "mixer",
    "ui"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git://github.com/websolutespa/bom.git"
  },
  "scripts": {
    "dev:vars": "bom vars ./src/theme/theme.json watch",
    "dev": "run-s dev:*",
    "build:vars": "bom vars ./src/theme/theme.json",
    "build": "run-s build:*",
    "lint": "eslint *.ts*",
    "test": "jest",
    "test-watch": "npm test -- --watch --silent=false",
    "coverage:integration": "npm run test -- --coverage",
    "coverage": "run-s -c --silent coverage:*",
    "compile": "bom compile",
    "prepack": "bom prepack",
    "postpack": "bom postpack"
  },
  "dependencies": {},
  "peerDependencies": {
    "@ariakit/react": ">= 0.4.11",
    "@copilot_bom/icons": "*",
    "@copilot_bom/models": "*",
    "@websolutespa/bom-core": "*",
    "@websolutespa/bom-mixer-forms": "*",
    "@websolutespa/bom-mixer-hooks": "*",
    "@websolutespa/bom-mixer-icons": "*",
    "@websolutespa/bom-mixer-models": "*",
    "@websolutespa/bom-mixer-store": "*",
    "@websolutespa/bom-mixer-ui": "*",
    "framer-motion": ">= 7.2.1",
    "iron-session": ">= 8.0.3",
    "next": ">= 14.1.4",
    "react-dom": ">= 18.2.0",
    "react": ">= 18.2.0",
    "react-error-boundary": ">= 4.0.11",
    "styled-components": ">= 5.3.11 <6.x.x",
    "zustand": ">= 4.4.0"
  },
  "devDependencies": {
    "@types/react-dom": "^18.2.24",
    "@types/react": "^18.2.75",
    "@types/styled-components": "^5.1.26",
    "@websolutespa/bom-cli": "*",
    "@websolutespa/test": "*",
    "@websolutespa/tsconfig": "*",
    "eslint-config-websolute": "*",
    "eslint": "^8.56.0",
    "npm-run-all": "^4.1.5",
    "raw-loader": "^4.0.2",
    "react-dom": "^18.2.0",
    "react-error-boundary": "^4.0.11",
    "react": "^18.2.0",
    "styled-components": "^5.3.11",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5",
    "zustand": "^4.4.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "sideEffects": false,
  "prepack": {
    "types": "./dist/types/index.d.ts",
    "main": "./dist/esm/index.js",
    "module": "./dist/esm/index.js",
    "source": "./src/index.ts"
  },
  "postpack": {
    "types": "./src/index.ts",
    "main": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "main": "./src/index.ts"
}